<div style="max-width: 1200px; margin: 0 auto; padding: 40px 20px;">
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">
    <div>
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '600x600' }}" alt="{{ product.title }}" style="width: 100%; border-radius: 10px;">
      {% endif %}
    </div>
    <div>
      <h1>{{ product.title }}</h1>
      <p style="font-size: 2rem; color: var(--color-accent-2); font-weight: bold; margin: 20px 0;">₹{{ product.price | money_without_currency }}</p>
      <p style="line-height: 1.6; margin-bottom: 30px;">{{ product.description }}</p>
      <form action="/cart/add" method="post" style="margin-bottom: 30px;">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" class="btn" style="width: 100%; justify-content: center;">Add to Cart</button>
      </form>
    </div>
  </div>
</div>
