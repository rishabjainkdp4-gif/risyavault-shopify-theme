{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "header_title",
      "label": "Store Name",
      "default": "Risyavault"
    }
  ]
}
{% endschema %}

<style>
  .header {
    background: linear-gradient(135deg, #4a90e2, #a8d5ba);
    color: white;
    padding: 1rem 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .header h1 {
    margin: 0;
    font-size: 1.75rem;
    font-weight: 700;
    color: white;
  }

  .header nav {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .header a {
    color: white;
    text-decoration: none;
    transition: opacity 0.3s;
    font-weight: 500;
  }

  .header a:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .header nav {
      gap: 1rem;
      font-size: 0.9rem;
    }
    
    .header h1 {
      font-size: 1.25rem;
    }
  }
</style>

<header class="header">
  <div class="header-content">
    <h1>{{ section.settings.header_title }}</h1>
    <nav>
      <a href="/">Home</a>
      <a href="/collections/all">Shop</a>
      <a href="/cart">Cart ({{ cart.item_count }})</a>
    </nav>
  </div>
</header>