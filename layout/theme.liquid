<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if page_title %}{{ page_title }}{% unless page_title contains shop.name %} | {{ shop.name }}{% endunless %}{% else %}{{ shop.name }}{% endif %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
  <link rel="canonical" href="{{ canonical_url }}">
  {{ content_for_header }}
  <link rel="stylesheet" href="{{ 'base.css' | asset_url }}">
  <style>
    :root {
      --color-primary: #ffffff;
      --color-secondary: #f8f8f8;
      --color-text: #2c2c2c;
      --color-accent-1: #a8d5ba;
      --color-accent-2: #4a90e2;
      --color-accent-3: #5b9fa8;
      --color-border: #e0e0e0;
    }
  </style>
</head>
<body>
  <header id="shopify-section-header" class="site-header">
    {% section 'header' %}
  </header>
  <main id="MainContent" class="main-content">
    {{ content_for_layout }}
  </main>
  <footer id="shopify-section-footer" class="site-footer">
    {% section 'footer' %}
  </footer>
  <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
</body>
</html>